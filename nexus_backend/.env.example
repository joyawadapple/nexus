# Nexus Backend — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Model ─────────────────────────────────────────────────────────────────────
# Default: claude-sonnet-4-6
MODEL=claude-sonnet-4-6

# Claude API timeout in seconds (default: 120)
CLAUDE_TIMEOUT_SECONDS=120

# ── App ───────────────────────────────────────────────────────────────────────
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=DEBUG

# CORS — JSON list of allowed origins. Default allows all (development only).
# Set to your frontend domain(s) in production.
# CORS_ORIGINS=["https://app.nexacloud.io"]

# Admin dashboard auth — set a strong random value in production.
# Leave empty to disable the guard (development default).
ADMIN_API_KEY=

# ── Voice services (optional) ─────────────────────────────────────────────────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
# Set LANGSMITH_TRACING=true to enable LangGraph + LangSmith trace export.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=nexus-dev
LANGSMITH_API_KEY=

    "500_internal_error": {
      "http_status": 500,
      "category": "server",
      "known_causes": ["nexa_infra_issue"],
      "typical_resolution_minutes": null,
      "auto_escalate": true,
      "description": "NexaAuth server error. Always escalate to engineering."
